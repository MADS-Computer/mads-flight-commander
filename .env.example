# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# MAVLink bridge WebSocket server (run separately — see /server)
EXPO_PUBLIC_MAVLINK_BRIDGE_URL=ws://localhost:5760

# ── server/.env only (never expose these in the app) ──────────────────────────
# Mapbox native SDK download token (sk.*) — needed at build time (expo prebuild)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your-mapbox-download-token

# Supabase service-role key — lets the bridge bypass RLS to write telemetry rows
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
