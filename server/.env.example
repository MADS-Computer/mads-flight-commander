# UDP port to listen on for incoming MAVLink packets (default: 14550)
MAVLINK_UDP_PORT=14550

# Bind address for the UDP socket (0.0.0.0 = all interfaces)
MAVLINK_UDP_HOST=0.0.0.0

# HTTP port for the socket.io server
SOCKET_PORT=5760

# Comma-separated list of allowed CORS origins for the socket.io server
# Use * to allow all (dev only)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000

# Optional: system ID this bridge claims when sending commands to drones (1–255)
BRIDGE_SYSTEM_ID=255

# ── Supabase (server-side only) ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — bypasses RLS so the bridge can write telemetry rows
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
